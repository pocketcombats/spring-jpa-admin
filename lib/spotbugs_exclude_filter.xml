<FindBugsFilter>

    <Match>
        <Or>
            <Bug pattern="EI_EXPOSE_REP"/>
            <Bug pattern="EI_EXPOSE_REP2"/>
        </Or>
    </Match>

    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!-- Nullability is enforced by NullAway; disable SpotBugs' overlapping null checks -->
    <Match>
        <Bug code="NP,RCN"/>
    </Match>

</FindBugsFilter>
